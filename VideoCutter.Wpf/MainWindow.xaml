<Window x:Class="VideoCutter.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        Title="Video Cutter" Height="780" Width="1180" MinHeight="720" MinWidth="1040">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="本地视频裁剪工具（WPF + FFmpeg + LibVLCSharp）"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.3*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="VideoHostBorder" Background="#111" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
                    <Grid>
                        <vlc:VideoView x:Name="VideoView" />

                        <Grid IsHitTestVisible="False" Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="StartMarkerBadge"
                                        Background="#CC118AB2"
                                        BorderBrush="#66FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,6"
                                        HorizontalAlignment="Left"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="开始点" Foreground="White" FontSize="12" />
                                        <TextBlock x:Name="StartMarkerTextBlock" Text="00:00:00" Foreground="White" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="EndMarkerBadge"
                                        Grid.Column="1"
                                        Background="#CCEF476F"
                                        BorderBrush="#66FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,6"
                                        HorizontalAlignment="Right"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="结束点" Foreground="White" FontSize="12" />
                                        <TextBlock x:Name="EndMarkerTextBlock" Text="00:00:00" Foreground="White" FontWeight="Bold" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Canvas x:Name="MarkerCanvas"
                                    Grid.Row="2"
                                    Height="34"
                                    Margin="0,0,0,4"
                                    SizeChanged="MarkerCanvas_SizeChanged">
                                <Border x:Name="RangeTrack"
                                        Canvas.Left="0"
                                        Canvas.Top="13"
                                        Height="8"
                                        CornerRadius="4"
                                        Background="#55000000"
                                        BorderBrush="#55FFFFFF"
                                        BorderThickness="1" />
                                <Border x:Name="SelectedRangeBar"
                                        Canvas.Left="0"
                                        Canvas.Top="13"
                                        Height="8"
                                        CornerRadius="4"
                                        Background="#AAFFD166"
                                        Visibility="Collapsed" />
                                <Border x:Name="StartMarkerLine"
                                        Canvas.Left="0"
                                        Canvas.Top="2"
                                        Width="3"
                                        Height="30"
                                        Background="#118AB2"
                                        CornerRadius="1.5"
                                        Visibility="Collapsed" />
                                <Border x:Name="EndMarkerLine"
                                        Canvas.Left="0"
                                        Canvas.Top="2"
                                        Width="3"
                                        Height="30"
                                        Background="#EF476F"
                                        CornerRadius="1.5"
                                        Visibility="Collapsed" />
                            </Canvas>
                        </Grid>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <Slider x:Name="PositionSlider"
                            Minimum="0"
                            Maximum="1000"
                            SmallChange="1"
                            LargeChange="25"
                            ValueChanged="PositionSlider_ValueChanged"
                            PreviewMouseLeftButtonDown="PositionSlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="PositionSlider_PreviewMouseLeftButtonUp" />
                    <DockPanel Margin="0,6,0,0">
                        <TextBlock x:Name="CurrentTimeTextBlock" Text="00:00:00" DockPanel.Dock="Left" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="定位到：" />
                            <TextBlock x:Name="SeekPreviewTextBlock" Text="00:00:00" FontWeight="SemiBold" />
                        </StackPanel>
                        <TextBlock x:Name="DurationTextBlock" Text="00:00:00" DockPanel.Dock="Right" HorizontalAlignment="Right" />
                    </DockPanel>
                </StackPanel>

                <WrapPanel Grid.Row="2" Margin="0,12,0,0">
                    <Button Width="90" Height="34" Margin="0,0,8,8" Content="打开视频" Click="BrowseInput_Click" />
                    <Button Width="80" Height="34" Margin="0,0,8,8" Content="播放" Click="Play_Click" />
                    <Button Width="80" Height="34" Margin="0,0,8,8" Content="暂停" Click="Pause_Click" />
                    <Button Width="80" Height="34" Margin="0,0,8,8" Content="停止" Click="Stop_Click" />
                    <Button Width="90" Height="34" Margin="0,0,8,8" Content="后退 5 秒" Click="Back5Seconds_Click" />
                    <Button Width="90" Height="34" Margin="0,0,8,8" Content="前进 5 秒" Click="Forward5Seconds_Click" />
                    <Button Width="100" Height="34" Margin="0,0,8,8" Content="设为开始点" Click="SetStartFromCurrent_Click" />
                    <Button Width="100" Height="34" Margin="0,0,8,8" Content="设为结束点" Click="SetEndFromCurrent_Click" />
                </WrapPanel>
            </Grid>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="输入文件" Margin="0,0,0,12">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding InputPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,12,0" VerticalContentAlignment="Center" />
                            <Button Grid.Column="1" Width="100" Height="32" Content="选择视频" Click="BrowseInput_Click" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="输出文件" Margin="0,0,0,12">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,12,0" VerticalContentAlignment="Center" />
                            <Button Grid.Column="1" Width="100" Height="32" Content="保存到..." Click="BrowseOutput_Click" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="裁剪参数" Margin="0,0,0,12">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="开始时间" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding StartTimeText, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="1" Text="结束时间" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EndTimeText, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,8" />

                            <TextBlock Grid.Row="2" Text="裁剪模式" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" Height="30" />
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="文件信息" Margin="0,0,0,12">
                        <StackPanel Margin="12">
                            <TextBlock Text="{Binding MediaInfoText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="处理状态" Margin="0,0,0,12">
                        <StackPanel Margin="12">
                            <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <ProgressBar Height="20" Minimum="0" Maximum="100" Value="{Binding Progress}" />
                            <TextBlock Text="{Binding ProgressText}" Margin="0,8,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="执行日志">
                        <TextBox Text="{Binding LogText}" Margin="12" Height="180" IsReadOnly="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" AcceptsReturn="True" />
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="快捷键：空格=播放/暂停，←/→=后退/前进5秒，I=设开始点，O=设结束点" VerticalAlignment="Center" DockPanel.Dock="Left" Margin="0,0,12,0" />
            <Button Width="140" Height="36" Content="开始裁剪" Click="Cut_Click" />
        </DockPanel>
    </Grid>
</Window>
